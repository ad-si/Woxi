{
  "name": "woxi-playground-deps",
  "version": "0.0.0",
  "private": true,
  "description": "Bundles the CodeMirror editor (and LZString) into a single self-contained ESM file served locally by the Woxi playground, so it no longer depends on the esm.sh CDN at runtime.",
  "type": "module",
  "scripts": {
    "build": "esbuild entry.mjs --bundle --format=esm --minify --legal-comments=none --outfile=../playground/vendor/codemirror.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/language": "^6.11.0",
    "@codemirror/legacy-modes": "^6.5.1",
    "@codemirror/state": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.2",
    "@codemirror/view": "^6.36.8",
    "lz-string": "^1.5.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  }
}
