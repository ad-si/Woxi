Cell["Format labels in a readable form:", "CodeText",
 TaggingRules->{},
 CellChangeTimes->{3.955531413577582*^9},
 CellID->105618477,ExpressionUUID->"08ddddac-611b-4785-b818-79e9b40561eb"],

Cell[BoxData[
 RowBox[{
  RowBox[{"labels", "=", 
   RowBox[{
    RowBox[{
     RowBox[{"Row", "[", 
      RowBox[{"#", ",", "\"\<:\>\""}], "]"}], "&"}], "/@", 
    InterpretationBox[
     DynamicModuleBox[{Typeset`open = False}, 
      TemplateBox[{"Expression", 
        RowBox[{"FromTabular", "[", 
          DynamicBox[
           FEPrivate`FrontEndResource["FEBitmaps", "IconizeEllipsis"]], "]"}], 
        GridBox[{{
           RowBox[{
             TagBox["\"Byte count: \"", "IconizedLabel"], "\[InvisibleSpace]", 
             TagBox["280", "IconizedItem"]}]}}, 
         GridBoxAlignment -> {"Columns" -> {{Left}}}, DefaultBaseStyle -> 
         "Column", 
         GridBoxItemSize -> {
          "Columns" -> {{Automatic}}, "Rows" -> {{Automatic}}}], 
        Dynamic[Typeset`open]},
       "IconizedObject"]],
     FromTabular[
      $CellContext`salesByRegion2[All, 
       TabularSchema[$CellContext`salesByRegion2]["KeyColumns"]], "Matrix"],
     SelectWithContents->True,
     Selectable->False]}]}], ";"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.955531225417945*^9, 3.955531249304624*^9}, {
