Cell["Show all the regions together in a stacked histogram:", "CodeText",
 TaggingRules->{},
 CellChangeTimes->{{3.955454152304964*^9, 3.955454168234123*^9}, {
  3.956145852152843*^9, 3.956145867501746*^9}, {3.95633344087328*^9, 
