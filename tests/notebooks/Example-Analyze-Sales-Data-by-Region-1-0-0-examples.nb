Notebook[{

Cell[CellGroupData[{
Cell["Analyze Aggregated Sales Data", "ResourceExampleTitle", "Title",
 TaggingRules->{},
 CellID->1997633514,ExpressionUUID->"ba66edd1-eb1d-471d-9a56-b6dbd3ab822d"],

Cell["\<\
Find the market sector with the highest revenue in each region\
\>", "ResourceExampleSubtitle", "InterpreterUsage",
 TaggingRules->{},
 CellID->467132600,ExpressionUUID->"ccf99630-c418-483a-90a3-239c0b92fe02"]
}, Open  ]],

Cell["\<\
Start with a table of sales information for a company. It tracks sales by \
date, geographic region, market sector, product type etc.:\
\>", "CodeText",
 TaggingRules->{},
 CellChangeTimes->{{3.955530925541197*^9, 3.955530931212175*^9}},
 CellID->663202958,ExpressionUUID->"6ba13017-1eb9-4819-9326-bcfc2422372e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sales", "=", 
  RowBox[{"Select", "[", 
   RowBox[{
    RowBox[{
    "ResourceData", "[", "\"\<Sample Tabular Data: Sales Data\>\"", "]"}], ",", 
    RowBox[{
     RowBox[{"#Date", "\[GreaterEqual]", 
      RowBox[{"DateObject", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"2015", ",", "7", ",", "1"}], "}"}], ",", "\"\<Day\>\""}], 
       "]"}]}], "&"}]}], "]"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{3.955618150352632*^9, 3.95614575405654*^9},
 CellLabel->"In[267]:=",
 CellID->2143895167,ExpressionUUID->"caf50cf3-dfea-4645-938b-4620a89d1a33"],

