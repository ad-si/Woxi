Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"selectedDataByRegion", "=", 
  RowBox[{"Map", "[", "\[IndentingNewLine]", "  ", 
   RowBox[{
    RowBox[{"regionName", " ", "\[Function]", " ", 
     RowBox[{"Select", "[", 
      RowBox[{"salesBySector", ",", 
       RowBox[{
        RowBox[{"#Region", "==", "regionName"}], " ", "&"}]}], "]"}]}], ",", 
    "regions"}], "]"}]}]], "Input",
