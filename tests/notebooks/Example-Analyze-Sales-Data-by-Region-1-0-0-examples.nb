Cell["Find the sector with the highest revenue in each region:", "CodeText",
 TaggingRules->{},
 CellChangeTimes->{{3.955557406479054*^9, 3.955557421511709*^9}},
 CellID->559288283,ExpressionUUID->"7558c8e5-215f-4883-8f96-fcf7cca76859"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Join", "@@", 
  RowBox[{"Map", "[", "\[IndentingNewLine]", "  ", 
   RowBox[{
    RowBox[{"regionData", " ", "\[Function]", " ", 
     RowBox[{"Select", "[", "\[IndentingNewLine]", "    ", 
      RowBox[{"regionData", ",", "\[IndentingNewLine]", "    ", 
       RowBox[{"Function", "[", 
        RowBox[{"record", ",", 
         RowBox[{
          RowBox[{"record", "[", "\"\<TotalRevenue\>\"", "]"}], "==", 
          RowBox[{"Max", "[", 
           RowBox[{"regionData", "[", 
            RowBox[{"All", ",", "\"\<TotalRevenue\>\""}], "]"}], "]"}]}]}], 
        "]"}]}], "\[IndentingNewLine]", "  ", "]"}]}], ",", 
    "selectedDataByRegion"}], "]"}]}]], "Input",
 TaggingRules->{},
