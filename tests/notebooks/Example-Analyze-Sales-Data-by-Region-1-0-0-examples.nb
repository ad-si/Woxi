Cell["Get a list of all the regions in the sales data:", "CodeText",
 TaggingRules->{},
 CellChangeTimes->{{3.955533139762279*^9, 3.955533145207127*^9}},
 CellID->731361822,ExpressionUUID->"87c9c477-bfba-4c91-9a5f-6dbc58993bb5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"regions", "=", 
  RowBox[{
   RowBox[{"DeleteDuplicates", "[", 
    RowBox[{"salesBySector", "[", 
     RowBox[{"[", 
      RowBox[{"All", ",", "\"\<Region\>\""}], "]"}], "]"}], "]"}], "//", 
   "Normal"}]}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.955533036529871*^9, 3.955533060647828*^9}, {
  3.955533107023718*^9, 3.955533118322682*^9}},
